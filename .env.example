# Banco de dados MySQL
DATABASE_URL="mysql://root:@localhost:3306/pdv_galetos"

# Auth.js / NextAuth (v5)
AUTH_SECRET="sua-chave-secreta-aqui-min-32-chars"
# Em desenvolvimento, NÃO defina AUTH_URL/NEXTAUTH_URL — a porta do `npm run dev` é detectada automaticamente.
# Em produção: AUTH_URL="https://seu-dominio.com"

# App
NEXT_PUBLIC_APP_NAME="PDV Galetos"
NEXT_PUBLIC_APP_VERSION="1.0.0"

# Stone Payments (maquininha física)
# Defina como "false" para usar produção (padrão: sandbox)
STONE_SANDBOX=true
# Segredo para validar assinatura HMAC dos webhooks Stone
# Obtido ao registrar o webhook no painel Stone
STONE_WEBHOOK_SECRET=

# NFC-e via Focus NFe (https://focusnfe.com.br)
# Opcional: sobrescreve a URL base (padrão auto por ambiente)
# FISCAL_FOCUS_URL=https://api.focusnfe.com.br
# Token e demais configurações são salvas em Settings (banco de dados)
