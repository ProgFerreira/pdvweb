{
  "name": "pdv-galetos",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "prisma generate && next build && cp -r .next/static .next/standalone/.next/static && mkdir -p public && cp -r public .next/standalone/public",
    "start": "node .next/standalone/server.js",
    "lint": "next lint",
    "test": "vitest run",
    "postinstall": "prisma generate",
    "db:push": "dotenv -e .env.local -- prisma db push",
    "db:seed": "dotenv -e .env.local -- npx tsx prisma/seed.ts",
    "db:seed-demo": "dotenv -e .env.local -- npx tsx prisma/seed-demo.ts",
    "db:studio": "dotenv -e .env.local -- prisma studio",
    "db:generate": "prisma generate",
    "db:backup": "dotenv -e .env.local -- npx tsx scripts/backup-db.ts",
    "ui-kit:build": "node ui-kit/scripts/build-css.mjs"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.0.1",
    "@prisma/client": "^6.8.2",
    "@radix-ui/react-alert-dialog": "^1.1.14",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-checkbox": "^1.3.2",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-popover": "^1.1.14",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.5",
    "@radix-ui/react-tabs": "^1.1.12",
    "@radix-ui/react-toast": "^1.2.14",
    "bcryptjs": "^3.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.511.0",
    "next": "^15.3.2",
    "next-auth": "^5.0.0-beta.28",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.56.4",
    "recharts": "^2.15.3",
    "sweetalert2": "^11.26.24",
    "tailwind-merge": "^3.3.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "zod": "^3.25.30",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.15.21",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.2",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.26.0",
    "eslint-config-next": "^15.3.2",
    "prisma": "^6.8.2",
    "tsx": "^4.19.4",
    "vitest": "^3.2.4"
  }
}
